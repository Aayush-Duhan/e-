# ── Snowflake Cortex REST API (required) ────────────────────────
SNOWFLAKE_PAT=
SNOWFLAKE_ACCOUNT_URL=https://<account-identifier>.snowflakecomputing.com

# ── Model ───────────────────────────────────────────────────────
CORTEX_MODEL=claude-4-sonnet
SNOWFLAKE_CORTEX_MODEL=
SNOWFLAKE_CORTEX_FUNCTION=complete

# ── App ─────────────────────────────────────────────────────────
EXECUTION_TOKEN=local-dev-token
PYTHON_EXEC_OUTPUT_ROOT=outputs
APP_SQLITE_PATH=
